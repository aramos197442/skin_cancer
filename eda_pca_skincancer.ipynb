    {
      "cell_type": "markdown",
      "source": [
        "## 1. Undersampling e Equilíbrio de Dados\n",
        "Reduzindo a classe `nv` para evitar o viés e a dispersão caótica nas camadas espectrais."
      ],
      "metadata": {
        "id": "loading"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"--- Carregando dataset via Streaming Híbrido (Ultra-Rápido) ---\")\n",
        "from datasets import load_dataset\n",
        "try:\n",
        "    from kaggle_secrets import UserSecretsClient\n",
        "    user_secrets = UserSecretsClient()\n",
        "    hf_token = user_secrets.get_secret(\"HF_TOKEN\")\n",
        "except: hf_token = None\n",
        "\n",
        "# 1. Abrir fluxo de dados (não baixa arquivos no disco)\n",
        "ds_stream = load_dataset(\"marmal88/skin_cancer\", split='train', streaming=True, token=hf_token)\n",
        "\n",
        "# 2. Configurar quotas para Undersampling On-the-fly\n",
        "# Baseado no log anterior: melanoma tem ~1076. Nevos limitaremos a 1600.\n",
        "class_quotas = {\n",
        "    'melanocytic_Nevi': 1600,\n",
        "    'melanoma': 1100,\n",
        "    'benign_keratosis-like_lesions': 1100,\n",
        "    'basal_cell_carcinoma': 500,\n",
        "    'actinic_keratoses': 400,\n",
        "    'vascular_lesions': 200,\n",
        "    'dermatofibroma': 150\n",
        "}\n",
        "class_counts = {k: 0 for k in class_quotas.keys()}\n",
        "\n",
        "X_list, y_list = [], []\n",
        "print(\"Iniciando captura inteligente de imagens...\")\n",
        "\n",
        "for example in ds_stream:\n",
        "    label = example['dx']\n",
        "    # Só processa se ainda houver 'vaga' na quota daquela classe\n",
        "    if label in class_quotas and class_counts[label] < class_quotas[label]:\n",
        "        img = example['image'].convert('RGB').resize(IMG_SIZE)\n",
        "        X_list.append(np.array(img, dtype='uint8'))\n",
        "        y_list.append(label)\n",
        "        class_counts[label] += 1\n",
        "        \n",
        "        total_now = sum(class_counts.values())\n",
        "        if total_now % 500 == 0: \n",
        "            print(f\"Capturadas: {total_now} imagens... {class_counts}\")\n",
        "\n",
        "X_raw = np.array(X_list)\n",
        "y_labels = np.array(y_list)\n",
        "del X_list, y_list, ds_stream\n",
        "gc.collect()\n",
        "\n",
        "label_to_id = {label: i for i, label in enumerate(np.unique(y_labels))}\n",
        "y_encoded = np.array([label_to_id[val] for val in y_labels])\n",
        "X_train_raw, X_test_raw, y_train, y_test = train_test_split(X_raw, y_encoded, test_size=0.15, random_state=42, stratify=y_encoded)\n",
        "\n",
        "weights = compute_class_weight('balanced', classes=np.unique(y_train), y=y_train)\n",
        "class_weights = dict(enumerate(weights))\n",
        "print(f\"--- Finalizado! Dataset equilibrado com {len(X_raw)} imagens ---\")"
        "\n",
        "label_to_id = {label: i for i, label in enumerate(np.unique(y_labels))}\n",
        "y_encoded = np.array([label_to_id[val] for val in y_labels])\n",
        "\n",
        "X_train_raw, X_test_raw, y_train, y_test = train_test_split(X_raw, y_encoded, test_size=0.15, random_state=42, stratify=y_encoded)\n",
        "\n",
        "del X_raw, ds_full\n",
        "gc.collect()"
      ],
      "metadata": {
        "id": "prep"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 2. Pipeline Dual-Stream (RGB + Espectral)\n",
        "Separamos as entradas para que a rede aprenda cada 'mundo' isoladamente antes da fusão."
      ],
      "metadata": {
        "id": "dual-pipeline"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "def dual_stream_mapping(image_uint8, label):\n",
        "    def process_func(img_numpy):\n",
        "        img_float = img_numpy.astype('float32') / 255.0\n",
        "        # Mapa Espectral\n",
        "        img_lab = rgb2lab(img_float)\n",
        "        l_ch = img_lab[:,:,0] / 100.0\n",
        "        a_ch = (img_lab[:,:,1] + 128.0) / 255.0\n",
        "        spectral = np.dstack([l_ch, a_ch]).astype('float32')\n",
        "        return img_float, spectral\n",
        "\n",
        "    rgb, spectral = tf.numpy_function(process_func, [image_uint8], [tf.float32, tf.float32])\n",
        "    rgb.set_shape((224, 224, 3))\n",
        "    spectral.set_shape((224, 224, 2))\n",
        "    \n",
        "    return {\"rgb_input\": rgb, \"spectral_input\": spectral}, label\n",
        "\n",
        "train_ds = tf.data.Dataset.from_tensor_slices((X_train_raw, y_train))\n",
        "train_ds = train_ds.shuffle(1000).map(dual_stream_mapping, num_parallel_calls=tf.data.AUTOTUNE).batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)\n",
        "\n",
        "test_ds = tf.data.Dataset.from_tensor_slices((X_test_raw, y_test))\n",
        "test_ds = test_ds.map(dual_stream_mapping, num_parallel_calls=tf.data.AUTOTUNE).batch(BATCH_SIZE).prefetch(tf.data.AUTOTUNE)"
      ],
      "metadata": {
        "id": "dataset-code"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 3. Arquitetura Multi-Input (Dual Stream Fusion)\n",
        "Combinamos o poder da `EfficientNetV2` para RGB com uma rede de texturas para o canal Espectral."
      ],
      "metadata": {
        "id": "model-md"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "with strategy.scope():\n",
        "    # RAMO 1: RGB Stream\n",
        "    input_rgb = layers.Input(shape=(224, 224, 3), name=\"rgb_input\")\n",
        "    base_rgb = tf.keras.applications.EfficientNetV2B0(input_shape=(224, 224, 3), include_top=False, weights='imagenet')\n",
        "    base_rgb.trainable = False\n",
        "    x_rgb = base_rgb(input_rgb)\n",
        "    x_rgb = layers.GlobalAveragePooling2D()(x_rgb)\n",
        "\n",
        "    # RAMO 2: Spectral Stream (Topografia + Vascularização)\n",
        "    input_spec = layers.Input(shape=(224, 224, 2), name=\"spectral_input\")\n",
        "    x_spec = layers.Conv2D(32, (3,3), activation='relu')(input_spec)\n",
        "    x_spec = layers.MaxPooling2D()(x_spec)\n",
        "    x_spec = layers.Conv2D(64, (3,3), activation='relu')(x_spec)\n",
        "    x_spec = layers.GlobalAveragePooling2D()(x_spec)\n",
        "\n",
        "    # FUSÃO DOS MUNDOS\n",
        "    combined = layers.Concatenate()([x_rgb, x_spec])\n",
        "    combined = layers.Dense(256, activation='relu')(combined)\n",
        "    combined = layers.Dropout(0.5)(combined)\n",
        "    output = layers.Dense(len(label_to_id), activation='softmax')(combined)\n",
        "\n",
        "    model = models.Model(inputs=[input_rgb, input_spec], outputs=output)\n",
        "    model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])"
      ],
      "metadata": {
        "id": "model-code"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 4. Calibração de Threshold e Avaliação de Segurança\n",
        "Implementamos o filtro de 85% para evitar diagnósticos precipitados."
      ],
      "metadata": {
        "id": "eval-md"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "early_stop = callbacks.EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True)\n",
        "print(\"--- Iniciando Treino Dual-Stream ---\")\n",
        "model.fit(train_ds, validation_data=test_ds, epochs=20, callbacks=[early_stop])\n",
        "\n",
        "print(\"\\n--- Executando Predição com Threshold de Segurança (85%) ---\")\n",
        "probs = model.predict(test_ds)\n",
        "final_preds = []\n",
        "THRESHOLD = 0.85\n",
        "\n",
        "for p in probs:\n",
        "    if np.max(p) >= THRESHOLD:\n",
        "        final_preds.append(np.argmax(p))\n",
        "    else:\n",
        "        # Se não houver confiança, marcamos como 'Inconclusivo'\n",
        "        final_preds.append(-1) \n",
        "\n",
        "print(\"\\nDistribuição de Confiança IA:\")\n",
        "inconclusive_count = final_preds.count(-1)\n",
        "print(f\"Casos Inconclusivos (Enviados para Médico): {inconclusive_count} ({100*inconclusive_count/len(final_preds):.1f}%)\")\n",
        "\n",
        "# Relatório apenas para os casos em que a IA teve certeza\n",
        "valid_indices = [i for i, x in enumerate(final_preds) if x != -1]\n",
        "y_test_valid = y_test[valid_indices]\n",
        "y_pred_valid = [final_preds[i] for i in valid_indices]\n",
        "\n",
        "print(\"\\nPerformance em Casos de Alta Certeza:\")\n",
        "if len(y_pred_valid) > 0:\n",
        "    print(classification_report(y_test_valid, y_pred_valid, target_names=list(label_to_id.keys())))\n",
        "else:\n",
        "    print(\"IA não atingiu threshold de 85% em nenhum caso.\")"
      ],
      "metadata": {
        "id": "results"
      },
      "execution_count": null,
      "outputs": []
    }
  ]
